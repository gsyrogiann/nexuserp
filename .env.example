VITE_APP_RUNTIME=server
VITE_BASE44_APP_ID=your_app_id
VITE_BASE44_APP_BASE_URL=https://your-app.base44.app
VITE_BASE44_FUNCTIONS_BASE_URL=https://your-app.base44.app/functions
VITE_SERVER_API_URL=http://127.0.0.1:4000/api
VITE_APP_ENVIRONMENT=development
VITE_APP_RELEASE=owned-runtime
VITE_OBSERVABILITY_ENDPOINT=
OBSERVABILITY_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.base44.app
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# If VITE_APP_RUNTIME=server, the frontend uses your own Express/Prisma API.
# If VITE_APP_RUNTIME=local, the frontend uses the built-in browser adapter.
DATABASE_URL="file:./dev.db"

# Server-side secrets
TELEGRAM_BOT_TOKEN=replace_with_new_token
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret
OPENAI_API_KEY=replace_with_openai_key
VOIP_API_KEY=replace_with_voip_key
VOIP_WEBHOOK_SECRET=replace_with_voip_webhook_secret
VOIP_OLLAMA_HOST=http://localhost:11434
VOIP_WHISPER_HOST=http://localhost:9000
