{
  "name": "AppSettings",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Unique settings key e.g. voip, telegram"
    },
    "telegram_bot_token": {
      "type": "string",
      "description": "Telegram Bot Token \u03b1\u03c0\u03cc \u03c4\u03bf BotFather"
    },
    "telegram_webhook_url": {
      "type": "string",
      "description": "Webhook URL \u03b3\u03b9\u03b1 \u03c4\u03bf Telegram bot"
    },
    "telegram_test_chat_id": {
      "type": "string",
      "description": "Chat ID \u03b3\u03b9\u03b1 test \u03bc\u03ae\u03bd\u03c5\u03bc\u03b1 \u03b5\u03ba\u03ba\u03af\u03bd\u03b7\u03c3\u03b7\u03c2"
    },
    "voip_host": {
      "type": "string",
      "description": "3CX Host URL e.g. https://pbx.company.com"
    },
    "voip_api_key": {
      "type": "string",
      "description": "API key / shared secret for webhook auth"
    },
    "voip_webhook_secret": {
      "type": "string",
      "description": "Webhook HMAC secret"
    },
    "ollama_host": {
      "type": "string",
      "description": "Local Ollama host e.g. http://localhost:11434"
    },
    "whisper_host": {
      "type": "string",
      "description": "Local Whisper API host e.g. http://localhost:9000"
    }
  },
  "required": [
    "key"
  ]
}