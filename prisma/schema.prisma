generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AppRecord {
  id        Int      @id @default(autoincrement())
  entity    String
  recordId  String   @unique
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entity])
}

model AppMeta {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
